# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# JWT_SECRET: Security token signature key. Provide a long random string.
JWT_SECRET=some_extremely_unpredictable_secret_guid_token_string

# CLOUDINARY_CLOUD_NAME: Cloudinary workspace name for media persistence
CLOUDINARY_CLOUD_NAME=

# CLOUDINARY_API_KEY: Cloudinary auth key
CLOUDINARY_API_KEY=

# CLOUDINARY_API_SECRET: Cloudinary private secret
CLOUDINARY_API_SECRET=

# EMAIL_SERVICE: Optional mail carrier (e.g. gmail, sendgrid). Fallbacks to local console logging if unconfigured.
EMAIL_SERVICE=
EMAIL_USER=
EMAIL_PASS=
EMAIL_HOST=
EMAIL_PORT=

# MONGODB_URI: Connection string for MongoDB instance
MONGODB_URI=


