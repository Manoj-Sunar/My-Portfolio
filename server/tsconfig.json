{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "skipLibCheck": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": false,
    "outDir": "dist"
  },
  "include": [
    "server.ts",
    "config/**/*",
    "controllers/**/*",
    "middleware/**/*",
    "models/**/*",
    "routes/**/*",
    "services/**/*",
    "types/**/*",
    "utils/**/*",
    "validations/**/*"
  ]
}
